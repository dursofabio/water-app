{
  "name": "water-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:e2e": "playwright test",
    "test:import-excel": "vitest run scripts/import-excel.spec.mjs",
    "test:rules": "node src/test/firestore-rules.test.mjs",
    "emulators": "firebase emulators:start --only firestore,auth --project acquaapp-dev",
    "emulators:all": "firebase emulators:start --project acquaapp-dev",
    "seed": "node scripts/seed.mjs",
    "import:excel": "FIRESTORE_EMULATOR_HOST=127.0.0.1:8080 node scripts/import-excel.mjs",
    "deploy": "ng build && firebase deploy"
  },
  "private": true,
  "packageManager": "npm@10.9.8",
  "dependencies": {
    "@angular/cdk": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "^22.0.0",
    "@angular/material": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@firebase/rules-unit-testing": "^5.0.1",
    "firebase": "^12.14.0",
    "firebase-admin": "^14.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@playwright/test": "^1.60.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}
